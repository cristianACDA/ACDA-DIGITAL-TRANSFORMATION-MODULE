# ACDA Digital Transformation Module — variabile de mediu
# Copiază în .env şi completează valorile reale. NU commita .env-ul.

# ── Server HTTP port (default 3001)
PORT=3001

# ── Google Drive upload (P6-T2)
# OAuth2 credentials obţinute din Google Cloud Console.
# Setup:
#   1. Creează proiect în https://console.cloud.google.com
#   2. Activează Google Drive API
#   3. Creează OAuth client (Desktop) → obţii CLIENT_ID + CLIENT_SECRET
#   4. Foloseşte OAuth playground cu scope https://www.googleapis.com/auth/drive.file
#      pentru a obţine REFRESH_TOKEN (contul care va deţine fişierele uploaded).
#   5. Opţional: creează un folder părinte în Drive şi pune ID-ul în
#      GOOGLE_DRIVE_ROOT_FOLDER_ID. Dacă e gol, se foloseşte „root" (My Drive).
#
# Alternativ: copiază variantele JSON în server/.gdrive-credentials.json.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
